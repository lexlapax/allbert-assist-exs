# Copy to `.env` and fill in. Used by `direnv` / `dotenv` style loaders.
# These are read at runtime via `config/runtime.exs`.

# Anthropic (Claude) — used by the :fast / :capable / :thinking aliases
ANTHROPIC_API_KEY=

# OpenAI — used by the :gpt alias
OPENAI_API_KEY=

# Ollama — used by the :local alias. Defaults to http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434
